# Backend API base URL used by client code (must include /v1).
NEXT_PUBLIC_API_URL=https://api.cradlen.com/v1

# Backend base URL used by server route handlers / the patient proxy.
# Falls back to NEXT_PUBLIC_API_URL, then https://api.cradlen.com/v1.
API_BASE_URL=https://api.cradlen.com/v1

# --- Error monitoring (Sentry) -------------------------------------------------
# Sentry DSN exposed to the browser (public client key). Leave blank to disable
# Sentry locally — the SDK is a no-op without it.
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (defaults to NEXT_PUBLIC_SENTRY_DSN when unset).
SENTRY_DSN=
# Source-map upload token — set in CI / Vercel only (NEVER commit a real value).
# Without it, builds run fine but skip source-map upload.
SENTRY_AUTH_TOKEN=
